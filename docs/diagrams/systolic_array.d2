# Activation flow (horizontal) - 绿色数据流
act0 -> pe00 -> pe01 -> pe02 -> pe03 {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
    animated: true
  }
}
act1 -> pe10 -> pe11 -> pe12 -> pe13 {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
    animated: true
  }
}
act2 -> pe20 -> pe21 -> pe22 -> pe23 {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
    animated: true
  }
}
act3 -> pe30 -> pe31 -> pe32 -> pe33 {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
    animated: true
  }
}

# Psum flow (vertical) - 蓝色累加流
pe00 -> pe10 -> pe20 -> pe30 -> res0 {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}
pe01 -> pe11 -> pe21 -> pe31 -> res1 {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}
pe02 -> pe12 -> pe22 -> pe32 -> res2 {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}
pe03 -> pe13 -> pe23 -> pe33 -> res3 {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}
