direction: right

# 全局连线样式：使用直线
connection: {
  style.stroke-width: 3
  style.border-radius: 0
}

title: |md
  # 4×4 Weight-Stationary 收缩阵列
  C[i][j] = Σ A[i][k] × W[k][j]
| {
  near: top-center
  style.font-size: 18
  style.bold: true
}

# 全局样式配置
vars: {
  pe-color: "#64B5F6"
  act-color: "#A5D6A7"
  res-color: "#90CAF9"
  border-color: "#37474F"
}

act0: "actIn(0)" {
  shape: rectangle
  style: {
    fill: ${act-color}
    stroke: ${border-color}
    stroke-width: 2
    font-size: 13
    bold: true
  }
}
act1: "actIn(1)" {
  shape: rectangle
  style: {
    fill: ${act-color}
    stroke: ${border-color}
    stroke-width: 2
    font-size: 13
    bold: true
  }
}
act2: "actIn(2)" {
  shape: rectangle
  style: {
    fill: ${act-color}
    stroke: ${border-color}
    stroke-width: 2
    font-size: 13
    bold: true
  }
}
act3: "actIn(3)" {
  shape: rectangle
  style: {
    fill: ${act-color}
    stroke: ${border-color}
    stroke-width: 2
    font-size: 13
    bold: true
  }
}

pe00: "PE[0][0]\nW₀₀" {
  style: {
    fill: ${pe-color}
    stroke: ${border-color}
    stroke-width: 2
    font-size: 11
    bold: true
  }
}
