direction: down

# 全局连线样式：使用直线
connection: {
  style.stroke-width: 3
  style.border-radius: 0
}

title: |md
  # 存储层次对比
| {
  near: top-center
  style.font-size: 20
  style.bold: true
}

# 全局样式配置
vars: {
  border-color: "#37474F"
  l0-color: "#FFCC80"
  l1-color: "#A5D6A7"
  l2-color: "#FFF59D"
  hbm-color: "#CFD8DC"
}

npu: 昇腾 NPU {
  style: {
    fill: "#ECEFF1"
    stroke: ${border-color}
    stroke-width: 4
    font-size: 16
    bold: true
    shadow: true
  }

  hbmCtrl: HBM Controller\n计算 die 侧接口 {
    shape: rectangle
    style: {
      fill: "#FFE0B2"
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  hbm: HBM Model\n仿真外部存储\n4096×128b\nLatency=10 {
    shape: cylinder
    style: {
      fill: ${hbm-color}
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  l2: L2 Buffer\n片上共享 2048×128b\nLatency=1 {
    shape: rectangle
    style: {
      fill: ${l2-color}
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  ub: UB (per-core)\n片上私有 256×128b\nLatency=1 {
    shape: rectangle
    style: {
      fill: ${l1-color}
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  l0: weightBuf / actBuf\n寄存器级\nLatency=0 {
    shape: rectangle
    style: {
      fill: ${l0-color}
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }

  hbmCtrl -> hbm: req / resp {
    style: {
      stroke: "#546E7A"
      stroke-width: 3
      font-size: 12
    }
  }
  hbm -> l2: 测试预加载 {
    style: {
      stroke: "#546E7A"
      stroke-width: 3
      font-size: 12
    }
  }
  l2 -> ub: DMA_LOAD\nDMA_STORE {
    style: {
      stroke: "#E65100"
      stroke-width: 3
      font-size: 12
      bold: true
    }
  }
  ub -> l0: LOAD\nSTORE {
    style: {
      stroke: "#2E7D32"
      stroke-width: 3
      font-size: 12
      bold: true
    }
  }
}

gpu: 英伟达 GPU {
  style: {
    fill: "#ECEFF1"
    stroke: ${border-color}
    stroke-width: 4
    font-size: 16
    bold: true
    shadow: true
  }

  hbmCtrl: HBM Controller\n全局仲裁 {
    shape: rectangle
    style: {
      fill: "#FFE0B2"
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  gmem: HBM Model\n片外 4096×128b\nLatency=10 {
    shape: cylinder
    style: {
      fill: ${hbm-color}
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  shmem: SharedMem (per-SM)\n片上 256×128b\nLatency=1 {
    shape: rectangle
    style: {
      fill: ${l2-color}
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  reg: RegFile (per-Warp)\n16×32b\nLatency=0 {
    shape: rectangle
    style: {
      fill: ${l1-color}
      stroke: ${border-color}
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }

  hbmCtrl -> gmem: req / resp {
    style: {
      stroke: "#546E7A"
      stroke-width: 3
      font-size: 12
      bold: true
    }
  }
  hbmCtrl -> reg: LD / ST\n(含延迟等待) {
    style: {
      stroke: "#C62828"
      stroke-width: 3
      font-size: 12
      bold: true
    }
  }
  shmem -> reg: SHM {
    style: {
      stroke: "#4A148C"
      stroke-width: 3
      font-size: 12
      bold: true
    }
  }
}

real_npu: 真实昇腾 (参考) {
  style: {
    fill: "#F5F5F5"
    stroke: ${border-color}
    stroke-width: 3
    stroke-dash: 5
    font-size: 16
    bold: true
  }

  r_hbm: HBM {
    shape: cylinder
    style: {
      fill: ${hbm-color}
      stroke: ${border-color}
      stroke-width: 2
      font-size: 12
    }
  }
  r_l2: L2 (共享) {
    shape: rectangle
    style: {
      fill: ${l2-color}
      stroke: ${border-color}
      stroke-width: 2
      font-size: 12
    }
  }
  r_l1: L1 (私有) {
    shape: rectangle
    style: {
      fill: ${l1-color}
      stroke: ${border-color}
      stroke-width: 2
      font-size: 12
    }
  }
  r_l0: L0A/L0B/L0C {
    shape: rectangle
    style: {
      fill: ${l0-color}
      stroke: ${border-color}
      stroke-width: 2
      font-size: 12
    }
  }

  r_hbm -> r_l2: MTE {
    style: {
      stroke: "#546E7A"
      stroke-width: 2
    }
  }
  r_l2 -> r_l1: MTE {
    style: {
      stroke: "#546E7A"
      stroke-width: 2
    }
  }
  r_l1 -> r_l0: MTE {
    style: {
      stroke: "#546E7A"
      stroke-width: 2
    }
  }
}
